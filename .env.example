# Feature Flags
ENABLE_MVP_MODE=true
ENABLE_MULTI_TENANT=false
ENABLE_GENERATOR=false
ENABLE_EV_CHARGERS=false
ENABLE_REVENUE_ANALYTICS=false

# Database
# For Docker Compose: use timescaledb:5432
# For local development: use localhost:5432
DATABASE_URL=postgresql+asyncpg://jsenergy:jsenergy_dev_password@timescaledb:5432/jsenergy_db

# MQTT
MQTT_BROKER_URL=mqtt://mosquitto:1883
MQTT_BROKER_TLS_URL=mqtts://mosquitto:8883
MQTT_USERNAME=jsenergy
MQTT_PASSWORD=jsenergy_dev_password

# JWT
# Generate a random 64+ character string for production
JWT_SECRET_KEY=dev_secret_key_change_in_production_64_chars_minimum_please_use_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# EPEX API (optional)
EPEX_API_KEY=
EPEX_API_URL=https://api.epex.com

# Admin (MVP mode)
ADMIN_EMAIL=admin@jsenergy.nl
ADMIN_PASSWORD_HASH=

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api

# Frontend Environment Variables (for docker-compose.dev.yml)
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api
NEXT_PUBLIC_ENABLE_MVP_MODE=true
NEXT_PUBLIC_ENABLE_GENERATOR=false
NEXT_PUBLIC_ENABLE_EV_CHARGERS=false
NEXT_PUBLIC_ENABLE_REVENUE_ANALYTICS=false

# Docker Compose - Database Password
POSTGRES_PASSWORD=jsenergy_dev_password
